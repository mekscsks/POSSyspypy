         <property name="minimumHeight"><number>46</number></property>
        </widget>
       </item>
      </layout>
     </widget>

     <!-- PAGE 2: END SHIFT SUMMARY -->
     <widget class="QWidget" name="pageEnd">
      <layout class="QVBoxLayout" name="endLayout">
