            <property name="text"><string>Notes (optional)</string></property>
           </widget>
          </item>
          <item>
           <widget class="QTextEdit" name="txtEndNotes">
            <property name="maximumHeight"><number>60</number></property>
           </widget>
          </item>
         </layout>
        </widget>
       </item>
       <item>
        <layout class="QHBoxLayout">
         <item>
          <widget class="QPushButton" name="btnBackToActive">
           <property name="objectName"><string>btnSecondary</string></property>
           <property name="text"><string>← Back</string></property>
          </widget>
         </item>
         <item>
          <widget class="QPushButton" name="btnConfirmEnd">
           <property name="objectName"><string>btnDanger</string></property>
           <property name="text"><string>Confirm End Shift</string></property>
