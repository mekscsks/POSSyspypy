         <property name="objectName"><string>btnPrimary</string></property>
         <property name="text"><string>▶  Open Shift</string></property>
         <property name="minimumHeight"><number>46</number></property>
        </widget>
       </item>
      </layout>
     </widget>

     <!-- PAGE 1: ACTIVE SHIFT -->
     <widget class="QWidget" name="pageActive">
      <layout class="QVBoxLayout" name="activeLayout">
       <property name="spacing"><number>10</number></property>

       <!-- Session info card -->
       <item>
        <widget class="QFrame" name="cardFrame">
         <layout class="QVBoxLayout" name="infoCardLayout">
          <property name="leftMargin"><number>14</number></property>
          <property name="topMargin"><number>12</number></property>
          <property name="rightMargin"><number>14</number></property>
          <property name="bottomMargin"><number>12</number></property>
          <property name="spacing"><number>4</number></property>
          <item>
           <widget class="QLabel" name="lblSessionInfo">
            <property name="text"><string>Session info</string></property>
