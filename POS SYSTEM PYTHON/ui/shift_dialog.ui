          </item>
          <item>
           <widget class="QLabel" name="lblSessionSales">
            <property name="text"><string>Sales this shift: ₱0.00  (0 transactions)</string></property>
            <property name="styleSheet"><string>font-size:13px;font-weight:bold;color:#2e7d32;</string></property>
           </widget>
          </item>
         </layout>
        </widget>
       </item>

       <!-- Cash Adjustment card -->
       <item>
        <widget class="QFrame" name="cardFrame">
         <layout class="QVBoxLayout" name="adjCardLayout">
          <property name="leftMargin"><number>14</number></property>
          <property name="topMargin"><number>12</number></property>
          <property name="rightMargin"><number>14</number></property>
          <property name="bottomMargin"><number>12</number></property>
          <property name="spacing"><number>8</number></property>
          <item>
           <widget class="QLabel">
            <property name="text"><string>Cash Adjustment</string></property>
            <property name="styleSheet"><string>font-weight:bold;color:#1a73e8;</string></property>
           </widget>
          </item>
          <item>
           <layout class="QHBoxLayout">
            <item>
             <widget class="QComboBox" name="cmbAdjType">
              <item><property name="text"><string>Cash In</string></property></item>
