             </widget>
            </item>
            <item>
             <widget class="QDoubleSpinBox" name="spinAdjAmount">
              <property name="minimum"><double>0.01</double></property>
              <property name="maximum"><double>999999.99</double></property>
              <property name="decimals"><number>2</number></property>
              <property name="value"><double>0.00</double></property>
