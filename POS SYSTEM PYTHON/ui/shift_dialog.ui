<ui version="4.0">
 <class>ShiftDialog</class>
 <widget class="QDialog" name="ShiftDialog">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>480</width><height>560</height></rect>
  </property>
  <property name="windowTitle"><string>Shift Management</string></property>
  <property name="modal"><bool>true</bool></property>
  <property name="styleSheet">
   <string>QDialog{background:#f0f4f8;}
    QLabel#lblTitle{font-size:16px;font-weight:bold;color:#1a73e8;}
    QLabel{font-size:13px;color:#333;}
    QLineEdit,QDoubleSpinBox,QTextEdit{padding:8px;border:1px solid #ccc;border-radius:5px;font-size:13px;background:white;}
    QLineEdit:focus,QDoubleSpinBox:focus,QTextEdit:focus{border:2px solid #1a73e8;}
    QPushButton#btnPrimary{background:#1a73e8;color:white;border:none;border-radius:5px;font-size:14px;font-weight:bold;padding:10px;}
    QPushButton#btnPrimary:hover{background:#1558b0;}
    QPushButton#btnDanger{background:#e53935;color:white;border:none;border-radius:5px;font-size:14px;font-weight:bold;padding:10px;}
    QPushButton#btnDanger:hover{background:#b71c1c;}
    QPushButton#btnSecondary{background:#eee;color:#333;border:none;border-radius:5px;font-size:13px;padding:9px;}
    QPushButton#btnSecondary:hover{background:#ddd;}
    QFrame#cardFrame{background:white;border-radius:8px;}
    QComboBox{padding:8px;border:1px solid #ccc;border-radius:5px;font-size:13px;background:white;}
   </string>
  </property>

  <layout class="QVBoxLayout" name="mainLayout">
   <property name="leftMargin"><number>24</number></property>
   <property name="topMargin"><number>24</number></property>
   <property name="rightMargin"><number>24</number></property>
   <property name="bottomMargin"><number>24</number></property>
   <property name="spacing"><number>14</number></property>

   <!-- TITLE -->
   <item>
    <widget class="QLabel" name="lblTitle">
     <property name="text"><string>Shift Management</string></property>
     <property name="alignment"><set>Qt::AlignCenter</set></property>
    </widget>
   </item>

   <!-- STATUS BANNER -->
   <item>
    <widget class="QLabel" name="lblStatus">
     <property name="text"><string>No active shift</string></property>
     <property name="alignment"><set>Qt::AlignCenter</set></property>
     <property name="styleSheet"><string>background:#fff3e0;color:#e65100;border-radius:5px;padding:8px;font-weight:bold;font-size:12px;</string></property>
    </widget>
   </item>

   <!-- STACKED WIDGET — pages: 0=Start, 1=Active, 2=End Summary -->
   <item>
    <widget class="QStackedWidget" name="stackedWidget">

     <!-- PAGE 0: START SHIFT -->
     <widget class="QWidget" name="pageStart">
      <layout class="QVBoxLayout" name="startLayout">
       <property name="spacing"><number>12</number></property>
       <item>
        <widget class="QFrame" name="cardFrame">
         <layout class="QVBoxLayout" name="startCardLayout">
          <property name="leftMargin"><number>16</number></property>
          <property name="topMargin"><number>16</number></property>
          <property name="rightMargin"><number>16</number></property>
          <property name="bottomMargin"><number>16</number></property>
          <property name="spacing"><number>10</number></property>
          <item>
           <widget class="QLabel" name="lblOpeningCash">
            <property name="text"><string>Opening Cash (₱)</string></property>
           </widget>
          </item>
          <item>
           <widget class="QDoubleSpinBox" name="spinOpeningCash">
            <property name="minimum"><double>0.00</double></property>
            <property name="maximum"><double>999999.99</double></property>
            <property name="decimals"><number>2</number></property>
            <property name="value"><double>0.00</double></property>
           </widget>
          </item>
          <item>
           <widget class="QLabel" name="lblStartNotes">
            <property name="text"><string>Notes (optional)</string></property>
           </widget>
          </item>
          <item>
           <widget class="QTextEdit" name="txtStartNotes">
            <property name="maximumHeight"><number>70</number></property>
            <property name="placeholderText"><string>e.g. Morning shift</string></property>
           </widget>
          </item>
         </layout>
        </widget>
